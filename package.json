{
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "debug": "SHELL_DEBUG=all dbus-run-session gnome-shell --devkit --wayland --no-x11",

    "build:clean": "rm -rf dist",
    "build:dirs": "mkdir -p dist/temp dist/builds",
    "build:copy": "cp -r src/* dist/temp/",
    "build:resources": "glib-compile-resources assets/org.gnome.shell.extensions.mediacontrols.gresource.xml --target=dist/temp/org.gnome.shell.extensions.mediacontrols.gresource --sourcedir=assets",
    "build:pack": "cd dist/temp && gnome-extensions pack -f -o ../builds/ --schema='../../assets/org.gnome.shell.extensions.mediacontrols.gschema.xml' --podir='../../assets/locale' --extra-source=helpers --extra-source=enums --extra-source=org.gnome.shell.extensions.mediacontrols.gresource --extra-source=utils .",

    "build": "pnpm run build:clean && pnpm run build:dirs && pnpm run build:copy && pnpm run build:resources && pnpm run build:pack",

    "ext:install": "gnome-extensions install --force \"dist/builds/${npm_package_name:-media-controls@ecabreral.github.com}.shell-extension.zip\"",
    "ext:uninstall": "gnome-extensions uninstall media-controls@ecabreral.github.com",
    "ext:enable": "gnome-extensions enable media-controls@ecabreral.github.com",
    "ext:disable": "gnome-extensions disable media-controls@ecabreral.github.com",
    "ext:prefs": "gnome-extensions prefs media-controls@ecabreral.github.com",
    "ext:upload": "gnome-extensions upload --accept-tos --user ecabreral ${EGO_ARGS} \"dist/builds/media-controls@ecabreral.github.com.shell-extension.zip\"",

    "translations:extract": "xgettext --from-code=UTF-8 --add-comments --join-existing --keyword=_ --keyword=C_:1c,2 --language=Javascript --output=assets/locale/media-controls@ecabreral.github.com.pot $(find . -type f \\( -name '*.ui' -o -name '*.js' \\) -not -path './node_modules/*')",
    "translations:merge": "for po in assets/locale/*.po; do msgmerge -U \"$po\" assets/locale/media-controls@ecabreral.github.com.pot; done && rm -f assets/locale/*.po~",
    "translations": "pnpm run translations:extract && pnpm run translations:merge"
  },
  "devDependencies": {
    "@girs/adw-1": "^1.10.0-4.0.4",
    "@girs/clutter-18": "^18.0.0-4.0.4",
    "@girs/cogl-2.0": "^2.0.0-4.0.4",
    "@girs/gdk-4.0": "^4.0.0-4.0.4",
    "@girs/gdkpixbuf-2.0": "^2.0.0-4.0.4",
    "@girs/gio-2.0": "^2.88.0-4.0.4",
    "@girs/gjs": "^4.0.4",
    "@girs/glib-2.0": "^2.88.0-4.0.4",
    "@girs/gnome-shell": "^50.0.3",
    "@girs/gobject-2.0": "^2.88.0-4.0.4",
    "@girs/graphene-1.0": "^1.0.0-4.0.4",
    "@girs/gtk-4.0": "^4.23.0-4.0.4",
    "@girs/meta-18": "^18.0.0-4.0.4",
    "@girs/pango-1.0": "^1.57.1-4.0.4",
    "@girs/shell-18": "^18.0.0-4.0.4",
    "@girs/soup-3.0": "^3.6.6-4.0.4",
    "@girs/st-18": "^18.0.0-4.0.4",
    "prettier": "^3.6.2"
  }
}

